// 5m + 15m FVGs
//
// Shows active 5-minute and 15-minute Fair Value Gaps from the current CME session (incl. overnight).
// Filled / invalidated gaps are removed from the chart.
//
// SETUP: Pine Editor → New → Blank indicator → paste ALL of this file
//
// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/

//@version=5
indicator("5m + 15m FVG", shorttitle="5m/15m FVG", overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// ── Inputs ───────────────────────────────────────────────────────────────────
grpDet = "Detection"
minGap     = input.float(0.0, "Min Gap Size (points)", minval=0, step=0.25, group=grpDet)
showBull   = input.bool(true, "Bullish FVGs", group=grpDet)
showBear   = input.bool(true, "Bearish FVGs", group=grpDet)
show5m     = input.bool(true, "Show 5m FVGs", group=grpDet)
show15m    = input.bool(true, "Show 15m FVGs", group=grpDet)
mitigateOn = input.string("Wick", "Remove When", options=["Wick", "Close"], group=grpDet)

grpSess = "Session"
tz = input.string("America/New_York", "Timezone", group=grpSess)

grpVis5 = "5m FVG Style"
bullFill5   = input.color(color.new(#b2dfdb, 78), "Bullish Fill", group=grpVis5)
bearFill5   = input.color(color.new(#ffcdd2, 78), "Bearish Fill", group=grpVis5)
bullBorder5 = input.color(color.new(#00897b, 50), "Bullish Border", group=grpVis5)
bearBorder5 = input.color(color.new(#c62828, 50), "Bearish Border", group=grpVis5)

grpVis15 = "15m FVG Style"
bullFill15   = input.color(color.new(#b2dfdb, 70), "Bullish Fill", group=grpVis15)
bearFill15   = input.color(color.new(#ffcdd2, 70), "Bearish Fill", group=grpVis15)
bullBorder15 = input.color(color.new(#00897b, 40), "Bullish Border", group=grpVis15)
bearBorder15 = input.color(color.new(#c62828, 40), "Bearish Border", group=grpVis15)

grpVis = "Display"
ceColor     = input.color(color.new(color.black, 0), "CE Line", group=grpVis)
showCE      = input.bool(true, "Show CE Line", group=grpVis)
showLabels  = input.bool(true, "Show FVG Labels", group=grpVis)
labelSize   = input.string("Small", "Label Size", options=["Tiny", "Small", "Normal"], group=grpVis)
extendRight = input.bool(true, "Extend Right", group=grpVis)

refTime = time
tf5 = "5"
tf15 = "15"
tf5Sec = timeframe.in_seconds(tf5)
tf15Sec = timeframe.in_seconds(tf15)

// ── CME session (today + overnight, starts 6:00 PM ET) ───────────────────────
cmeSessionStart(int t) =>
    y  = year(t, tz)
    mo = month(t, tz)
    d  = dayofmonth(t, tz)
    h  = hour(t, tz)
    evening = timestamp(tz, y, mo, d, 18, 0)
    h >= 18 ? evening : evening - 86400000

currentSessionStart = cmeSessionStart(refTime)

inCurrentSession(int formT) =>
    formT >= currentSessionStart and formT <= refTime

// ── Per-TF FVG pack ──────────────────────────────────────────────────────────
fvgPack() =>
    bull = low - high[2] > minGap
    bear = low[2] - high > minGap
    [bull, bear, low, high[2], low[2], high, time[2], time, high, low, close]

[b5, be5, bTop5, bBot5, sTop5, sBot5, left5, form5, invH5, invL5, invC5] = request.security(
     syminfo.tickerid, tf5, fvgPack(), barmerge.gaps_off, barmerge.lookahead_off)

[b15, be15, bTop15, bBot15, sTop15, sBot15, left15, form15, invH15, invL15, invC15] = request.security(
     syminfo.tickerid, tf15, fvgPack(), barmerge.gaps_off, barmerge.lookahead_off)

closed5 = ta.change(form5) != 0
closed15 = ta.change(form15) != 0

labelSz() =>
    labelSize == "Tiny" ? size.tiny : labelSize == "Normal" ? size.normal : size.small

zoneLabelText(int tfS) =>
    tfS == tf5Sec ? "5min FVG" : "15min FVG"

updateLabel(label lb, int xRight, float yTop, string lblText) =>
    label.set_xy(lb, xRight, yTop)
    label.set_text(lb, lblText)
    label.set_style(lb, label.style_label_lower_right)
    label.set_color(lb, color.new(color.white, 100))
    label.set_textcolor(lb, color.black)
    label.set_size(lb, labelSz())

// ── Storage ──────────────────────────────────────────────────────────────────
var box[]   boxes     = array.new_box()
var line[]  ceLines   = array.new_line()
var label[] labels    = array.new_label()
var float[] tops      = array.new_float()
var float[] bottoms   = array.new_float()
var bool[]  bulls     = array.new_bool()
var int[]   formTimes = array.new_int()
var int[]   tfSecs    = array.new_int()

hasZone(int formT, bool isBull, int tfS) =>
    bool found = false
    if array.size(formTimes) > 0
        for j = 0 to array.size(formTimes) - 1
            if array.get(formTimes, j) == formT and array.get(bulls, j) == isBull and array.get(tfSecs, j) == tfS
                found := true
                break
    found

zoneFilled(bool isBull, float top, float bottom, float iH, float iL, float iC) =>
    mitigateOn == "Close" ? (isBull ? iC < bottom : iC > top) : (isBull ? iL < bottom : iH > top)

removeZone(int i) =>
    box.delete(array.get(boxes, i))
    line ln = array.get(ceLines, i)
    if not na(ln)
        line.delete(ln)
    label lb = array.get(labels, i)
    if not na(lb)
        label.delete(lb)
    array.remove(boxes, i)
    array.remove(ceLines, i)
    array.remove(labels, i)
    array.remove(tops, i)
    array.remove(bottoms, i)
    array.remove(bulls, i)
    array.remove(formTimes, i)
    array.remove(tfSecs, i)

addZone(bool isBull, float top, float bottom, int leftT, int formT, int tfS) =>
    mid = (top + bottom) / 2.0
    bool is5 = tfS == tf5Sec
    fill = isBull ? (is5 ? bullFill5 : bullFill15) : (is5 ? bearFill5 : bearFill15)
    border = isBull ? (is5 ? bullBorder5 : bullBorder15) : (is5 ? bearBorder5 : bearBorder15)
    ext = extendRight ? extend.right : extend.none
    string lblText = zoneLabelText(tfS)
    b = box.new(leftT, top, formT, bottom, xloc=xloc.bar_time, extend=ext, bgcolor=fill, border_color=border, border_width=1)
    ln = line.new(leftT, mid, formT, mid, xloc=xloc.bar_time, extend=ext, color=showCE ? ceColor : color.new(ceColor, 100), style=line.style_dashed, width=1)
    int xRight = extendRight ? refTime : formT
    label lb = showLabels ? label.new(xRight, top, lblText, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_lower_right, color=color.new(color.white, 100), textcolor=color.black, size=labelSz()) : na
    array.push(boxes, b)
    array.push(ceLines, ln)
    array.push(labels, lb)
    array.push(tops, top)
    array.push(bottoms, bottom)
    array.push(bulls, isBull)
    array.push(formTimes, formT)
    array.push(tfSecs, tfS)

// ── Register new 5m FVGs ─────────────────────────────────────────────────────
if show5m and closed5 and b5 and showBull and inCurrentSession(form5) and not hasZone(form5, true, tf5Sec)
    addZone(true, bTop5, bBot5, left5, form5, tf5Sec)

if show5m and closed5 and be5 and showBear and inCurrentSession(form5) and not hasZone(form5, false, tf5Sec)
    addZone(false, sTop5, sBot5, left5, form5, tf5Sec)

// ── Register new 15m FVGs ────────────────────────────────────────────────────
if show15m and closed15 and b15 and showBull and inCurrentSession(form15) and not hasZone(form15, true, tf15Sec)
    addZone(true, bTop15, bBot15, left15, form15, tf15Sec)

if show15m and closed15 and be15 and showBear and inCurrentSession(form15) and not hasZone(form15, false, tf15Sec)
    addZone(false, sTop15, sBot15, left15, form15, tf15Sec)

// ── Maintain zones ───────────────────────────────────────────────────────────
if array.size(boxes) > 0
    for i = array.size(boxes) - 1 to 0
        int formT    = array.get(formTimes, i)
        int tfS      = array.get(tfSecs, i)
        bool isBull  = array.get(bulls, i)
        float top    = array.get(tops, i)
        float bottom = array.get(bottoms, i)

        bool is5 = tfS == tf5Sec
        float iH  = is5 ? invH5 : invH15
        float iL  = is5 ? invL5 : invL15
        float iC  = is5 ? invC5 : invC15
        int iForm = is5 ? form5 : form15

        if barstate.islast
            if not inCurrentSession(formT)
                removeZone(i)
                continue
            if showLabels
                int xRight = extendRight ? refTime : formT
                string lblText = zoneLabelText(tfS)
                label lb = array.get(labels, i)
                if na(lb)
                    lb := label.new(xRight, top, lblText, xloc=xloc.bar_time, yloc=yloc.price, style=label.style_label_lower_right, color=color.new(color.white, 100), textcolor=color.black, size=labelSz())
                    array.set(labels, i, lb)
                else
                    updateLabel(lb, xRight, top, lblText)

        if barstate.isconfirmed and formT < iForm and zoneFilled(isBull, top, bottom, iH, iL, iC)
            removeZone(i)
