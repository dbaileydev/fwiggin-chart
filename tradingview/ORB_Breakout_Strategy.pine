// Opening Range Breakout — OR stop, BE at 2R, FVG invalidation TP, opp FVG exit before 1R
//@version=5
strategy("MNQ ORB Breakout", overlay=true, max_boxes_count=50, max_lines_count=50,
     initial_capital=50000, currency=currency.USD,
     default_qty_type=strategy.fixed, default_qty_value=1,
     commission_type=strategy.commission.cash_per_contract, commission_value=0.62,
     slippage=1, pyramiding=0, calc_on_every_tick=false, process_orders_on_close=true)

// ── Entry types (add more here later) ────────────────────────────────────────
grpEntry = "Entry Types"
useOrbLong  = input.bool(true, "ORB Long (break + close above OR high)", group=grpEntry)
useOrbShort = input.bool(true, "ORB Short (break + close below OR low)", group=grpEntry)
useOrFadeLong  = input.bool(true, "OR Fade Long (ORL retest + confirm → ORH)", group=grpEntry)
useOrFadeShort = input.bool(true, "OR Fade Short (ORH retest + confirm → ORL)", group=grpEntry)

// ── Opening range ────────────────────────────────────────────────────────────
grpOr = "Opening Range"
rthSession   = input.session("0930-1600:23456", "US RTH Session (ET)", group=grpOr)
orSession    = input.session("0930-0931:23456", "OR Candle (1m)", group=grpOr)
tradeSession = input.session("0931-1600:23456", "Entry Window", group=grpOr)
tz           = input.string("America/New_York", "Session Timezone", group=grpOr)
flatAtClose  = input.bool(true, "Close All Positions at RTH End", group=grpOr)
skipUsHolidays = input.bool(true, "Skip US Market Holidays", group=grpOr,
     tooltip="No opening range or entries on NYSE/CME full-day closures (incl. Juneteenth).")

// ── Orders ───────────────────────────────────────────────────────────────────
grpExec = "Orders"
entryBufferTicks = input.int(1, "Entry Buffer Beyond OR (ticks)", minval=0, group=grpExec,
     tooltip="Long: enter above OR high. Short: enter below OR low.")
stopBufferTicks  = input.int(1, "ORB Stop Buffer Beyond OR (ticks)", minval=0, group=grpExec,
     tooltip="ORB breakout: long stop below ORL, short stop above ORH.")
fadeStopBufferTicks = input.int(1, "OR Fade Stop Buffer Outside OR (ticks)", minval=1, group=grpExec,
     tooltip="Fade short: stop above ORH. Fade long: stop below ORL.")
fadePriorWindowBars = input.int(30, "OR Fade Traverse Lookback (bars)", minval=1, group=grpExec,
     tooltip="On 1m, 30 bars ≈ 30 min. Count ORH→ORL / ORL→ORH traverses within this window.")
fadePriorMinTraverses = input.int(2, "OR Fade Min Range Traverses", minval=2, group=grpExec,
     tooltip="Require at least this many full OR traverses before fade entry.")
tickSize         = input.float(0.25, "Tick Size", minval=0.01, group=grpExec)
beAtR            = input.float(2.0, "Move Stop to BE at (R multiple)", minval=0.1, step=0.1, group=grpExec)
oneTradePerDay   = input.bool(false, "One ORB Trade Per Direction / Day", group=grpExec)
oneFadePerDay    = input.bool(false, "One OR Fade Per Direction / Day", group=grpExec)
requireOrReset   = input.bool(true, "Require Close Back Inside OR Before Re-Entry", group=grpExec,
     tooltip="Long: prior close at/below OR high. Short: prior close at/above OR low.")

// ── FVG exits (1m) ───────────────────────────────────────────────────────────
grpFvg = "FVG Exits (1m)"
fvgMinGap   = input.float(0.0, "Min FVG Size (points)", minval=0, step=0.25, group=grpFvg,
     tooltip="Minimum 3-candle gap size to count as an FVG.")
oppFvgMinR  = input.float(1.0, "Opposite FVG Exit Below (R)", minval=0.1, step=0.1, group=grpFvg,
     tooltip="If trade has not reached this R, exit when an opposite-direction FVG forms.")

// ── Position sizing ──────────────────────────────────────────────────────────
grpRisk = "Position Sizing"
tradeQty   = input.int(3, "Contracts", minval=1, group=grpRisk)
pointValue = input.float(2.0, "Point Value ($)", minval=0.01, group=grpRisk,
     tooltip="Used for exit PnL labels only.")

// ── Visuals ──────────────────────────────────────────────────────────────────
grpVis = "Visuals"
showOrBox = input.bool(true, "Draw OR Box", group=grpVis)

// ── Session / OR ─────────────────────────────────────────────────────────────
// NYSE/CME full-day closures (YYYYMMDD). Observed dates when holiday falls on a weekend.
var int[] usMarketHolidays = array.from(
     20240101, 20240115, 20240219, 20240329, 20240527, 20240619, 20240704, 20240902, 20241128, 20241225,
     20250101, 20250120, 20250217, 20250418, 20250526, 20250619, 20250704, 20250901, 20251127, 20251225,
     20260101, 20260119, 20260216, 20260403, 20260525, 20260619, 20260703, 20260907, 20261126, 20261225,
     20270101, 20270118, 20270215, 20270326, 20270531, 20270618, 20270705, 20270906, 20271125, 20271224)

isUsHoliday(int ymd) =>
    skipUsHolidays and array.includes(usMarketHolidays, ymd)

barDateKey = year(time, tz) * 10000 + month(time, tz) * 100 + dayofmonth(time, tz)
dow        = dayofweek(time, tz)
isWeekday  = dow != dayofweek.saturday and dow != dayofweek.sunday
isTradingDay = isWeekday and not isUsHoliday(barDateKey)

inRth      = not na(time(timeframe.period, rthSession, tz))
inOrBar    = not na(time(timeframe.period, orSession, tz))
inTradeWin = not na(time(timeframe.period, tradeSession, tz))
newDay     = ta.change(time("D", tz))
rthEnded   = inRth[1] and not inRth

// Hard clock guard — session strings alone can miss ETH bars on MNQ
barMins      = hour(time, tz) * 60 + minute(time, tz)
inRthClock   = barMins >= 9 * 60 + 30 and barMins < 16 * 60
inEntryClock = barMins >= 9 * 60 + 31 and barMins < 16 * 60

var bool entriesLocked = false

if bool(newDay)
    entriesLocked := false

// Only lock after a real RTH close on a trading day (not holiday ETH artifacts)
if rthEnded and isTradingDay[1]
    entriesLocked := true

// Unlock when RTH opens on a new trading day (handles weekend/holiday bar gaps)
if isTradingDay and inRth and not inRth[1]
    entriesLocked := false

var float orHigh  = na
var float orLow   = na
var bool  orReady = false

if bool(newDay)
    orHigh  := na
    orLow   := na
    orReady := false

if inOrBar and isTradingDay
    orHigh := high
    orLow  := low

if inOrBar[1] and not inOrBar and isTradingDay
    orReady := true

var bool sessionTouchedOrh = false
var bool sessionTouchedOrl = false

if bool(newDay)
    sessionTouchedOrh := false
    sessionTouchedOrl := false

if orReady and isTradingDay and inRth
    if high >= orHigh
        sessionTouchedOrh := true
    if low <= orLow
        sessionTouchedOrl := true

orBothTouched = sessionTouchedOrh and sessionTouchedOrl

entryBuffer = entryBufferTicks * tickSize
stopBuffer  = stopBufferTicks * tickSize
fadeStopBuffer = fadeStopBufferTicks * tickSize

longEntry  = orReady and not na(orHigh) ? orHigh + entryBuffer : na
longStop   = orReady and not na(orLow)  ? orLow - stopBuffer : na
shortEntry = orReady and not na(orLow)  ? orLow - entryBuffer : na
shortStop  = orReady and not na(orHigh) ? orHigh + stopBuffer : na

// ── 1m FVG detection ─────────────────────────────────────────────────────────
bullFvgRaw = low > high[2] and low - high[2] >= fvgMinGap
bearFvgRaw = high < low[2] and low[2] - high >= fvgMinGap
bullFvgTop = low
bullFvgBot = high[2]
bearFvgTop = low[2]
bearFvgBot = high

formatExitComment(string exitName, float exitPrice, float initR) =>
    qty = math.abs(strategy.position_size)
    dir = strategy.position_size > 0 ? 1.0 : -1.0
    pts = (exitPrice - strategy.position_avg_price) * dir
    rr  = initR > 0 ? pts / initR : 0.0
    net = qty * pts * pointValue - qty * 0.62 * 2.0
    sign = net >= 0 ? "+$" : "-$"
    rrStr = (rr >= 0 ? "+" : "") + str.tostring(rr, "#.##") + "R"
    exitName + " (" + sign + str.tostring(math.abs(net), "#.##") + ", " + rrStr + ")"

// ── Breakout + trade state ───────────────────────────────────────────────────
var bool  longTakenToday   = false
var bool  shortTakenToday  = false
var bool  fadeLongTaken    = false
var bool  fadeShortTaken   = false
var bool  tradeBeArmed     = false
var bool  tradeHit1R       = false
var bool  tradeIsRange     = false
var string tradeEntryId    = na
var float tradeInitialStop = na
var float tradeStop        = na
var float tradeFvgLevel    = na
var int   tradeFvgBar      = na
var int   tradeEntryBar    = na
var int   fadeShortRetestBar   = na
var int   fadeLongRetestBar    = na
var int   lastOrhTouchBar       = na
var int   lastOrlTouchBar       = na
var int[] rangeTraverseBars     = array.new_int()

if bool(newDay)
    longTakenToday  := false
    shortTakenToday := false
    fadeLongTaken   := false
    fadeShortTaken  := false
    fadeShortRetestBar  := na
    fadeLongRetestBar   := na
    lastOrhTouchBar     := na
    lastOrlTouchBar     := na
    array.clear(rangeTraverseBars)

longResetOk  = not requireOrReset or close[1] <= orHigh
shortResetOk = not requireOrReset or close[1] >= orLow

longBreakout  = isTradingDay and orReady and inEntryClock and not entriesLocked and high > orHigh and close > orHigh and longResetOk
shortBreakout = isTradingDay and orReady and inEntryClock and not entriesLocked and low < orLow and close < orLow and shortResetOk

insideOr = orReady and close >= orLow and close <= orHigh

// OR fade: retest level → rejection candle → enter next bar if level holds
if orBothTouched and insideOr and low <= orHigh
    fadeShortRetestBar := bar_index
if orBothTouched and insideOr and high >= orLow
    fadeLongRetestBar := bar_index

if not na(fadeShortRetestBar) and close > orHigh
    fadeShortRetestBar := na
if not na(fadeLongRetestBar) and close < orLow
    fadeLongRetestBar := na

fadeShortReject = not na(fadeShortRetestBar) and bar_index >= fadeShortRetestBar and insideOr and
     close < open and close < orHigh
fadeLongReject  = not na(fadeLongRetestBar) and bar_index >= fadeLongRetestBar and insideOr and
     close > open and close > orLow

// Prior fade = at least N full range traverses (ORH→ORL or ORL→ORH) in lookback window
if orReady and orBothTouched and isTradingDay and inRth
    if low <= orLow
        if not na(lastOrhTouchBar) and bar_index > lastOrhTouchBar and bar_index - lastOrhTouchBar <= fadePriorWindowBars
            array.push(rangeTraverseBars, bar_index)
        lastOrlTouchBar := bar_index
    if high >= orHigh
        if not na(lastOrlTouchBar) and bar_index > lastOrlTouchBar and bar_index - lastOrlTouchBar <= fadePriorWindowBars
            array.push(rangeTraverseBars, bar_index)
        lastOrhTouchBar := bar_index

if array.size(rangeTraverseBars) > 0
    for i = array.size(rangeTraverseBars) - 1 to 0
        if bar_index - array.get(rangeTraverseBars, i) > fadePriorWindowBars
            array.remove(rangeTraverseBars, i)

fadePriorOk = array.size(rangeTraverseBars) >= fadePriorMinTraverses

orFadeShortSig = fadeShortReject[1] and insideOr and close <= orHigh and fadePriorOk
orFadeLongSig  = fadeLongReject[1] and insideOr and close >= orLow and fadePriorOk

// Fade stops sit outside the retested boundary (short above ORH, long below ORL)
fadeShortStop = orHigh + fadeStopBuffer
fadeLongStop  = orLow - fadeStopBuffer

canEnter = isTradingDay and orReady and inRth and inTradeWin and inRthClock and inEntryClock and not entriesLocked and strategy.position_size == 0

longOk = useOrbLong and canEnter and longBreakout and longStop < longEntry and
     (not oneTradePerDay or not longTakenToday)
shortOk = useOrbShort and canEnter and shortBreakout and shortStop > shortEntry and
     (not oneTradePerDay or not shortTakenToday)
fadeShortOk = useOrFadeShort and canEnter and orFadeShortSig and fadeShortStop > close and
     (not oneFadePerDay or not fadeShortTaken)
fadeLongOk = useOrFadeLong and canEnter and orFadeLongSig and fadeLongStop < close and
     (not oneFadePerDay or not fadeLongTaken)

// ── Exit management ──────────────────────────────────────────────────────────
// OR fade: limit TP at opposite OR side; stop outside retested boundary
if strategy.position_size > 0 and tradeIsRange and tradeEntryId == "OR Fade Long" and not na(orHigh) and not na(orLow)
    strategy.exit("OR Fade Long Exit", "OR Fade Long", limit=orHigh, stop=orLow - fadeStopBuffer,
         comment_profit="OR Fade Long ORH TP", comment_loss="OR Fade Long Stop (below ORL)")

if strategy.position_size < 0 and tradeIsRange and tradeEntryId == "OR Fade Short" and not na(orHigh) and not na(orLow)
    strategy.exit("OR Fade Short Exit", "OR Fade Short", limit=orLow, stop=orHigh + fadeStopBuffer,
         comment_profit="OR Fade Short ORL TP", comment_loss="OR Fade Short Stop (above ORH)")

if strategy.position_size > 0 and not na(tradeInitialStop) and bar_index > tradeEntryBar and not tradeIsRange
    entryPx = strategy.position_avg_price
    initR   = entryPx - tradeInitialStop
    exitTag = na(tradeEntryId) ? "ORB Long" : tradeEntryId

    minRPx  = entryPx + initR * oppFvgMinR
    bePx    = entryPx + initR * beAtR

    if initR > 0 and high >= minRPx
        tradeHit1R := true

    if not tradeBeArmed and initR > 0 and high >= bePx
        tradeBeArmed := true
        tradeStop := math.max(tradeStop, entryPx)

    if tradeBeArmed and bullFvgRaw and bar_index > tradeEntryBar
        tradeFvgLevel := bullFvgBot
        tradeFvgBar   := bar_index

    bullFvgInvalidClose = tradeBeArmed and not na(tradeFvgLevel) and not na(tradeFvgBar) and bar_index > tradeFvgBar and close < open and close < tradeFvgLevel

    if not tradeHit1R and bearFvgRaw and bar_index > tradeEntryBar
        strategy.close(exitTag, comment=formatExitComment(exitTag + " Opp FVG Exit", close, initR))
    else if bullFvgInvalidClose
        strategy.close(exitTag, comment=formatExitComment(exitTag + " FVG TP", close, initR))
    else if low <= tradeStop
        strategy.close(exitTag, comment=formatExitComment(exitTag + (tradeBeArmed ? " BE Stop" : " Stop"), tradeStop, initR))

if strategy.position_size < 0 and not na(tradeInitialStop) and bar_index > tradeEntryBar and not tradeIsRange
    entryPx = strategy.position_avg_price
    initR   = tradeInitialStop - entryPx
    exitTag = na(tradeEntryId) ? "ORB Short" : tradeEntryId

    minRPx  = entryPx - initR * oppFvgMinR
    bePx    = entryPx - initR * beAtR

    if initR > 0 and low <= minRPx
        tradeHit1R := true

    if not tradeBeArmed and initR > 0 and low <= bePx
        tradeBeArmed := true
        tradeStop := math.min(tradeStop, entryPx)

    if tradeBeArmed and bearFvgRaw and bar_index > tradeEntryBar
        tradeFvgLevel := bearFvgTop
        tradeFvgBar   := bar_index

    bearFvgInvalidClose = tradeBeArmed and not na(tradeFvgLevel) and not na(tradeFvgBar) and bar_index > tradeFvgBar and close > open and close > tradeFvgLevel

    if not tradeHit1R and bullFvgRaw and bar_index > tradeEntryBar
        strategy.close(exitTag, comment=formatExitComment(exitTag + " Opp FVG Exit", close, initR))
    else if bearFvgInvalidClose
        strategy.close(exitTag, comment=formatExitComment(exitTag + " FVG TP", close, initR))
    else if high >= tradeStop
        strategy.close(exitTag, comment=formatExitComment(exitTag + (tradeBeArmed ? " BE Stop" : " Stop"), tradeStop, initR))

if flatAtClose and rthEnded and strategy.position_size != 0
    exitTag = na(tradeEntryId) ? "Position" : tradeEntryId
    if strategy.position_size > 0
        initR = strategy.position_avg_price - tradeInitialStop
        strategy.close(exitTag, comment=formatExitComment(exitTag + " RTH Close", close, initR))
    else
        initR = tradeInitialStop - strategy.position_avg_price
        strategy.close(exitTag, comment=formatExitComment(exitTag + " RTH Close", close, initR))

if longOk
    strategy.entry("ORB Long", strategy.long, qty=tradeQty, alert_message="ORB long")
    tradeBeArmed     := false
    tradeHit1R       := false
    tradeIsRange     := false
    tradeEntryId     := "ORB Long"
    tradeFvgLevel    := na
    tradeFvgBar      := na
    tradeInitialStop := longStop
    tradeStop        := longStop
    tradeEntryBar    := bar_index
    longTakenToday   := true
else if shortOk
    strategy.entry("ORB Short", strategy.short, qty=tradeQty, alert_message="ORB short")
    tradeBeArmed     := false
    tradeHit1R       := false
    tradeIsRange     := false
    tradeEntryId     := "ORB Short"
    tradeFvgLevel    := na
    tradeFvgBar      := na
    tradeInitialStop := shortStop
    tradeStop        := shortStop
    tradeEntryBar    := bar_index
    shortTakenToday  := true
else if fadeLongOk
    strategy.entry("OR Fade Long", strategy.long, qty=tradeQty, alert_message="OR fade long to ORH")
    tradeBeArmed     := false
    tradeHit1R       := false
    tradeIsRange     := true
    tradeEntryId     := "OR Fade Long"
    tradeFvgLevel    := na
    tradeFvgBar      := na
    tradeInitialStop := fadeLongStop
    tradeStop        := fadeLongStop
    tradeEntryBar    := bar_index
    fadeLongTaken    := true
    fadeLongRetestBar  := na
else if fadeShortOk
    strategy.entry("OR Fade Short", strategy.short, qty=tradeQty, alert_message="OR fade short to ORL")
    tradeBeArmed     := false
    tradeHit1R       := false
    tradeIsRange     := true
    tradeEntryId     := "OR Fade Short"
    tradeFvgLevel    := na
    tradeFvgBar      := na
    tradeInitialStop := fadeShortStop
    tradeStop        := fadeShortStop
    tradeEntryBar    := bar_index
    fadeShortTaken   := true
    fadeShortRetestBar := na

if strategy.position_size == 0 and not longOk and not shortOk and not fadeLongOk and not fadeShortOk
    tradeBeArmed     := false
    tradeHit1R       := false
    tradeIsRange     := false
    tradeEntryId     := na
    tradeInitialStop := na
    tradeStop        := na
    tradeFvgLevel    := na
    tradeFvgBar      := na
    tradeEntryBar    := na

// ── Visuals (RTH only) ───────────────────────────────────────────────────────
var box orBox     = na
var int orDrawDay = na

if bool(newDay) or rthEnded
    if not na(orBox)
        box.delete(orBox)
        orBox := na
    orDrawDay := na

if showOrBox and orReady and inRth and not na(orHigh) and not na(orLow) and orDrawDay != dayofmonth
    if not na(orBox)
        box.delete(orBox)
    orBox := box.new(bar_index - 1, orHigh, bar_index, orLow,
         border_color=color.orange, bgcolor=color.new(color.orange, 90))
    orDrawDay := dayofmonth

if not na(orBox) and inRth
    box.set_right(orBox, bar_index)

showOrLines = orReady and inRth
plot(showOrLines ? orHigh : na, "OR High", color=color.orange, linewidth=2, style=plot.style_linebr)
plot(showOrLines ? orLow : na, "OR Low", color=color.orange, linewidth=2, style=plot.style_linebr)
