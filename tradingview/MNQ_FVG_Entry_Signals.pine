// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// MNQ Fair Value Gap Entry Signals — quality filters: displacement, min stop, entry EMA

//@version=5
indicator("MNQ FVG Entry Signals", overlay=true, max_boxes_count=500, max_labels_count=500, max_lines_count=500)

// ── Inputs ───────────────────────────────────────────────────────────────────
grpFvg    = "FVG Detection"
minGap    = input.float(8.0, "Min Gap Size (points)", minval=0, group=grpFvg)
maxAge    = input.int(24, "Max Setup Age (bars)", minval=1, group=grpFvg)
showBoxes = input.bool(true, "Draw FVG Boxes", group=grpFvg)
boxExtend = input.int(20, "Box Extend Right (bars)", minval=1, group=grpFvg)

grpDisp = "Displacement Filter"
useDisp      = input.bool(true, "Require Strong Displacement", group=grpDisp)
dispAtrLen   = input.int(14, "ATR Period", minval=1, group=grpDisp)
dispAtrMult  = input.float(1.5, "Min Range vs ATR", minval=0.1, step=0.1, group=grpDisp)
dispBodyPct  = input.float(0.6, "Min Body % of Range", minval=0.1, maxval=1.0, step=0.05, group=grpDisp)

grpTrend = "Trend Filter"
useTrendForm = input.bool(true, "Require EMA at FVG Formation", group=grpTrend)
useTrendEntry = input.bool(true, "Require EMA at Entry", group=grpTrend)
emaLen   = input.int(50, "EMA Period", minval=1, group=grpTrend)

grpEntry = "Entry / Exit Levels"
entryMode = input.string("Edge", "Entry Mode", options=["CE", "Edge", "Full"], group=grpEntry)
requireRejection = input.bool(true, "Require Rejection Candle", group=grpEntry)
stopTicks = input.int(2, "Stop Buffer (ticks)", minval=0, group=grpEntry)
minStop   = input.float(20.0, "Min Stop Distance (points)", minval=0, group=grpEntry)
rr        = input.float(1.5, "Risk : Reward", minval=0.1, step=0.1, group=grpEntry)
tickSize  = input.float(0.25, "Tick Size", minval=0.01, group=grpEntry)

grpSide = "Direction"
tradeBull = input.bool(true, "Bullish FVGs", group=grpSide)
tradeBear = input.bool(true, "Bearish FVGs", group=grpSide)
oneAtTime = input.bool(true, "One Active Setup at a Time", group=grpSide)

grpSess = "Session"
useSession = input.bool(true, "Use Session Filter", group=grpSess)
sess       = input.session("0930-1130", "Session (chart timezone)", group=grpSess)

grpVis = "Visuals"
showLevels = input.bool(true, "Show Entry / Stop / Target Lines", group=grpVis)
bullColor  = input.color(color.new(color.teal, 75), "Bullish FVG", group=grpVis)
bearColor  = input.color(color.new(color.red, 75), "Bearish FVG", group=grpVis)
longColor  = input.color(color.lime, "Long Entry", group=grpVis)
shortColor = input.color(color.fuchsia, "Short Entry", group=grpVis)

// ── Helpers ──────────────────────────────────────────────────────────────────
buffer = stopTicks * tickSize
ema    = ta.ema(close, emaLen)
atr    = ta.atr(dispAtrLen)
inSess = not useSession or not na(time(timeframe.period, sess))

calcEntry(float top, float bottom, bool isBull) =>
    mid = (top + bottom) / 2.0
    if isBull
        entryMode == "CE" ? mid : entryMode == "Edge" ? top : bottom
    else
        entryMode == "CE" ? mid : entryMode == "Edge" ? bottom : top

calcStop(float top, float bottom, bool isBull) =>
    isBull ? bottom - buffer : top + buffer

calcTarget(float entry, float stop, bool isBull) =>
    risk = isBull ? entry - stop : stop - entry
    isBull ? entry + risk * rr : entry - risk * rr

calcRisk(float entry, float stop, bool isBull) =>
    isBull ? entry - stop : stop - entry

trendOkForm(bool isBull) =>
    not useTrendForm or (isBull ? close >= ema : close <= ema)

trendOkEntry(bool isBull) =>
    not useTrendEntry or (isBull ? close >= ema : close <= ema)

rejectionOk(bool isBull, float entry) =>
    not requireRejection or (isBull ? close > open and close >= entry : close < open and close <= entry)

gapTouched(float top, float bottom) =>
    low <= top and high >= bottom

entryTouched(float entry) =>
    low <= entry and high >= entry

fvgInvalidated(float top, float bottom, bool isBull) =>
    isBull ? low < bottom : high > top

// Middle candle [1] must be impulsive displacement
displacementOk() =>
    if not useDisp
        true
    else
        dRange = high[1] - low[1]
        dBody  = math.abs(close[1] - open[1])
        dRange > 0 and dRange >= atr[1] * dispAtrMult and dBody / dRange >= dispBodyPct

setupQuality(float top, float bottom, bool isBull) =>
    entry = calcEntry(top, bottom, isBull)
    stop  = calcStop(top, bottom, isBull)
    risk  = calcRisk(entry, stop, isBull)
    risk > 0 and risk >= minStop

// ── FVG detection ────────────────────────────────────────────────────────────
bullRaw = low > high[2]
bearRaw = high < low[2]

bTop    = low
bBottom = high[2]
bSize   = bTop - bBottom

sTop    = low[2]
sBottom = high
sSize   = sTop - sBottom

newBull = bullRaw and bSize >= minGap and tradeBull and trendOkForm(true) and inSess and displacementOk() and setupQuality(bTop, bBottom, true)
newBear = bearRaw and sSize >= minGap and tradeBear and trendOkForm(false) and inSess and displacementOk() and setupQuality(sTop, sBottom, false)

takeBull = newBull and (not newBear or bSize >= sSize)
takeBear = newBear and (not newBull or sSize > bSize)

// ── Pending setup state ──────────────────────────────────────────────────────
var float pTop     = na
var float pBottom  = na
var bool  pBull    = false
var int   pBar     = na
var float pEntry   = na
var float pStop    = na
var float pTarget  = na
var bool  pActive  = false
var bool  inTrade  = false

var line entryLine  = na
var line stopLine   = na
var line targetLine = na

if pActive and not inTrade
    if fvgInvalidated(pTop, pBottom, pBull) or bar_index - pBar > maxAge
        pActive := false
        pTop := na
        pBottom := na
        pBar := na
        pEntry := na
        pStop := na
        pTarget := na
        if not na(entryLine)
            line.delete(entryLine)
            entryLine := na
        if not na(stopLine)
            line.delete(stopLine)
            stopLine := na
        if not na(targetLine)
            line.delete(targetLine)
            targetLine := na

canArm = not inTrade and (not oneAtTime or not pActive)

if takeBull and canArm
    pTop := bTop
    pBottom := bBottom
    pBull := true
    pBar := bar_index
    pEntry := calcEntry(bTop, bBottom, true)
    pStop := calcStop(bTop, bBottom, true)
    pTarget := calcTarget(pEntry, pStop, true)
    pActive := true
    inTrade := false
    if not na(entryLine)
        line.delete(entryLine)
    if not na(stopLine)
        line.delete(stopLine)
    if not na(targetLine)
        line.delete(targetLine)
    if showLevels
        entryLine := line.new(bar_index, pEntry, bar_index + 1, pEntry, color=longColor, width=2)
        stopLine := line.new(bar_index, pStop, bar_index + 1, pStop, color=color.red, style=line.style_dashed)
        targetLine := line.new(bar_index, pTarget, bar_index + 1, pTarget, color=color.green, style=line.style_dashed)
    if showBoxes
        box.new(bar_index - 2, bTop, bar_index + boxExtend, bBottom, bgcolor=bullColor, border_color=color.teal)

if takeBear and canArm
    pTop := sTop
    pBottom := sBottom
    pBull := false
    pBar := bar_index
    pEntry := calcEntry(sTop, sBottom, false)
    pStop := calcStop(sTop, sBottom, false)
    pTarget := calcTarget(pEntry, pStop, false)
    pActive := true
    inTrade := false
    if not na(entryLine)
        line.delete(entryLine)
    if not na(stopLine)
        line.delete(stopLine)
    if not na(targetLine)
        line.delete(targetLine)
    if showLevels
        entryLine := line.new(bar_index, pEntry, bar_index + 1, pEntry, color=shortColor, width=2)
        stopLine := line.new(bar_index, pStop, bar_index + 1, pStop, color=color.red, style=line.style_dashed)
        targetLine := line.new(bar_index, pTarget, bar_index + 1, pTarget, color=color.green, style=line.style_dashed)
    if showBoxes
        box.new(bar_index - 2, sTop, bar_index + boxExtend, sBottom, bgcolor=bearColor, border_color=color.red)

if pActive and showLevels and not na(entryLine)
    line.set_x2(entryLine, bar_index + 1)
    line.set_x2(stopLine, bar_index + 1)
    line.set_x2(targetLine, bar_index + 1)

// ── Entry signals (EMA checked at entry bar) ─────────────────────────────────
longSignal  = pActive and pBull and not inTrade and gapTouched(pTop, pBottom) and entryTouched(pEntry) and trendOkEntry(true) and rejectionOk(true, pEntry)
shortSignal = pActive and not pBull and not inTrade and gapTouched(pTop, pBottom) and entryTouched(pEntry) and trendOkEntry(false) and rejectionOk(false, pEntry)

if longSignal
    inTrade := true
    label.new(bar_index, low, "LONG\n" + str.tostring(pEntry, "#.##") + "\nSL " + str.tostring(pStop, "#.##") + "\nTP " + str.tostring(pTarget, "#.##"),
         style=label.style_label_up, color=longColor, textcolor=color.black, size=size.small)

if shortSignal
    inTrade := true
    label.new(bar_index, high, "SHORT\n" + str.tostring(pEntry, "#.##") + "\nSL " + str.tostring(pStop, "#.##") + "\nTP " + str.tostring(pTarget, "#.##"),
         style=label.style_label_down, color=shortColor, textcolor=color.white, size=size.small)

plotshape(longSignal, title="Long Entry", style=shape.triangleup, location=location.belowbar, color=longColor, size=size.small, text="LONG")
plotshape(shortSignal, title="Short Entry", style=shape.triangledown, location=location.abovebar, color=shortColor, size=size.small, text="SHORT")

if inTrade and pActive
    stopped  = pBull ? low <= pStop : high >= pStop
    targeted = pBull ? high >= pTarget : low <= pTarget
    if stopped or targeted
        inTrade := false
        pActive := false
        pTop := na
        pBottom := na
        pBar := na
        pEntry := na
        pStop := na
        pTarget := na
        if not na(entryLine)
            line.delete(entryLine)
            entryLine := na
        if not na(stopLine)
            line.delete(stopLine)
            stopLine := na
        if not na(targetLine)
            line.delete(targetLine)
            targetLine := na

plot(ema, "EMA", color=color.new(color.orange, 0), linewidth=1)
plot(pActive ? pEntry : na, "Pending Entry", color=color.new(color.yellow, 0), style=plot.style_circles, linewidth=2)

alertcondition(longSignal, title="FVG Long Entry", message="MNQ FVG: LONG entry — check chart")
alertcondition(shortSignal, title="FVG Short Entry", message="MNQ FVG: SHORT entry — check chart")
