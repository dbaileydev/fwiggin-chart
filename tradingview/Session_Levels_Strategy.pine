// Session Levels — blank canvas for strategy development
//@version=5
strategy("Session Levels", overlay=true,
     max_lines_count=500, max_labels_count=500, max_boxes_count=50,
     initial_capital=50000, currency=currency.USD,
     calc_on_every_tick=true, process_orders_on_close=false)

// ── Session inputs ───────────────────────────────────────────────────────────
grpSess = "Sessions"
rthSession = input.session("0930-1600:23456", "RTH Session", group=grpSess,
     tooltip="Regular trading hours. Lines extend across this session.")
tz = input.string("America/New_York", "Timezone", group=grpSess)
tzCt = "America/Chicago"
skipUsHolidays = input.bool(true, "Skip US Holidays", group=grpSess)
skipFomcDays = input.bool(true, "Skip FOMC Days", group=grpSess,
     tooltip="No trades on FOMC rate decision days (statement release day, ET).")

grpOr = "Opening Range"
orMinutes = input.int(15, "OR Duration (minutes)", minval=1, maxval=60, group=grpOr,
     tooltip="High/low of the first N minutes after RTH open.")

grpStrat = "VWAP Cross Strategy"
useStrategy = input.bool(true, "Enable Strategy", group=grpStrat)
tradeQty = input.int(6, "Contracts", minval=1, group=grpStrat)
oneTradePerDay = input.bool(false, "One Trade Per Day", group=grpStrat)
stopBufferTicks = input.int(2, "Live Stop Buffer (ticks)", minval=0, group=grpStrat,
     tooltip="Stop buffer for live entries, initial stops, and trail swing offset.")
trailLookback = input.int(3, "Trail Swing Lookback (bars)", minval=1, group=grpStrat,
     tooltip="After trail R:R is hit, trail stop behind swing high/low of last N bars.")
trailActivateRr = input.float(2, "Trail Activate R:R", minval=0.5, step=0.25, group=grpStrat,
     tooltip="Start trailing stop once price reaches this multiple of initial risk.")
rrRatio = input.float(3.0, "Risk:Reward (TP)", minval=0.5, step=0.25, group=grpStrat)
partialExitRr = input.float(2, "Partial Exit R:R", minval=0.25, step=0.25, group=grpStrat)
partialExitPct = input.float(50.0, "Partial Close %", minval=1, maxval=99, step=1, group=grpStrat)
waitForOr = input.bool(true, "Wait For OR Completion", group=grpStrat,
     tooltip="Only trade after the opening range period ends.")
entryStartHourEt = input.int(10, "No Entries Before Hour (ET)", minval=0, maxval=23, group=grpStrat)
entryStartMinuteEt = input.int(0, "No Entries Before Minute (ET)", minval=0, maxval=59, group=grpStrat,
     tooltip="Earliest entry time in America/New_York. Default 10:00 AM ET.")
lossCooldown = input.int(10, "Loss Cooldown (bars)", minval=0, group=grpStrat,
     tooltip="After a losing trade closes this session, wait N bars before next entry.")
sameDirCooldown = input.int(20, "Same Direction Cooldown (bars)", minval=0, group=grpStrat,
     tooltip="After any long/short closes, wait N bars before another entry in that same direction.")
useSkipFirstReclaimAfterWin = input.bool(true, "Skip First Reclaim After Win", group=grpStrat,
     tooltip="After a winning long, if price closes back below session VWAP then crosses above again, skip the first new long signal (mirror for shorts above VWAP).")
oppBodyPct = input.float(0.60, "Long Opposite Candle Body %", minval=0.0, maxval=1.0, step=0.05, group=grpStrat,
     tooltip="Skip long if prior bar is strong bearish (body >= this % of range). Set to 0 to disable.")
oppBodyPctShort = input.float(0.70, "Short Opposite Candle Body %", minval=0.0, maxval=1.0, step=0.05, group=grpStrat,
     tooltip="Skip short if prior bar is strong bullish (body >= this % of range). Set to 0 to disable.")
flattenAt2Pm = input.bool(true, "Flatten All at 2PM CT", group=grpStrat,
     tooltip="At the flatten time (CT), close all open positions (winners, losers, and trailing).")
flattenEndHourCt = input.int(14, "Flatten Hour (CT)", minval=0, maxval=23, group=grpStrat)
flattenEndMinuteCt = input.int(0, "Flatten Minute (CT)", minval=0, maxval=59, group=grpStrat,
     tooltip="Close all positions at or after this Central Time. Default: 2:00 PM CT.")
grpDefense = "Loss Streak Defense"
useLossStreakDefense = input.bool(true, "Enable Loss Streak Defense", group=grpDefense,
     tooltip="After consecutive losing trades, pause entries or trade reduced size until defense clears.")
lossStreakMode = input.string("Pause", "Loss Streak Action", options=["Pause", "Reduce Size"], group=grpDefense,
     tooltip="Pause: no live entries until a paper trade wins. Reduce Size: keep trading at Defense Contracts until a live win.")
streakLossTrades = input.int(3, "Loss Trades to Activate", minval=1, group=grpDefense,
     tooltip="Consecutive losing closed trades before defense mode activates.")
streakWinTrades = input.int(1, "Wins to Resume Full Size", minval=1, group=grpDefense,
     tooltip="Reduce Size: consecutive winning closed trades to return to full Contracts.")
defenseContracts = input.int(3, "Defense Contracts", minval=1, group=grpDefense,
     tooltip="Live contract size while in Reduce Size defense mode.")
pauseSimWinRr = input.float(2, "Paper Win R:R", minval=0.25, step=0.25, group=grpDefense,
     tooltip="Pause mode only: paper trade must reach this R:R before stop to resume full size.")
pauseStopBufferTicks = input.int(15, "Paper Stop Buffer (ticks)", minval=0, group=grpDefense,
     tooltip="Pause mode only: stop buffer for paper trades. Does not affect Live Stop Buffer (ticks).")

maxVwapDistPts = input.float(50.0, "Max Session VWAP Distance (pts)", minval=0, step=5.0, group=grpStrat,
     tooltip="Skip if entry close is farther than this from session VWAP. Set to 0 to disable.")
skipFlatVwaps = input.bool(true, "Skip When VWAPs Flat / Compressed", group=grpStrat,
     tooltip="No entries when session + prior-day VWAP are close together and not sloping (chop).")
vwapSlopeLookback = input.int(6, "VWAP Flat Lookback (bars)", minval=1, group=grpStrat,
     tooltip="Bars to measure VWAP movement. 6 bars = 30 min on a 5m chart.")
minVwapSpreadPts = input.float(15.0, "Min VWAP Spread (pts)", minval=0, step=5.0, group=grpStrat,
     tooltip="Require session and prior-day VWAP to be at least this far apart. Blocks early-session chop when VWAPs sit on top of each other. Set to 0 to disable.")
maxVwapSpreadPts = input.float(20.0, "Max VWAP Spread (pts)", minval=0, step=5.0, group=grpStrat,
     tooltip="Session and prior-day VWAP must be farther apart than this. Both within = compressed chop.")
maxVwapSlopePts = input.float(15.0, "Max VWAP Slope (pts)", minval=0, step=5.0, group=grpStrat,
     tooltip="Each VWAP must rise/fall more than this over the lookback. Both below = flat. Set to 0 to disable.")
maxEntryRiskPts = input.float(80.0, "Max Entry Bar Risk (pts)", minval=0, step=5.0, group=grpStrat,
     tooltip="Skip if signal-bar stop risk exceeds this. Set to 0 to disable.")
entryEndHourCt = input.int(13, "No Entries After Hour (CT)", minval=0, maxval=23, group=grpStrat)
entryEndMinuteCt = input.int(30, "No Entries After Minute (CT)", minval=0, maxval=59, group=grpStrat,
     tooltip="No new entries at or after this Central Time (America/Chicago). Default: 1:30 PM CT.")
showSkipLabels = input.bool(true, "Show Skip Reasons", group=grpStrat,
     tooltip="Orange X on skipped signals. Click that bar → Data Window (right panel) shows the skip reason.")

grpCandle = "Candlestick Confirmation"
useCandleConfirm = input.bool(true, "Require Candle Alignment", group=grpCandle,
     tooltip="Signal bar must confirm VWAP cross direction via candlestick structure (pin bars, engulfing, conviction close).")
candlePinWickRatio = input.float(2.0, "Pin Bar Wick / Body Ratio", minval=1.0, step=0.25, group=grpCandle,
     tooltip="Hammer / shooting star: dominant wick must be at least this multiple of body size.")
candleMinBodyPct = input.float(0.35, "Marubozu Min Body %", minval=0.1, maxval=0.9, step=0.05, group=grpCandle,
     tooltip="Full-body candle: body must be at least this fraction of total range.")
candleClvThreshold = input.float(0.55, "Conviction Close Location", minval=0.5, maxval=0.9, step=0.05, group=grpCandle,
     tooltip="Long: close in upper fraction of range. Short: close in lower fraction. 0.55 = upper/lower 55%.")

grpVis = "Visuals"
showOrLines = input.bool(true, "OR High / Low", group=grpVis)
showOnLines = input.bool(true, "Overnight High / Low (ONH/ONL)", group=grpVis)
showPdLines = input.bool(true, "Previous Day High / Low (PDH/PDL)", group=grpVis)
showPriorDayVwap = input.bool(true, "Prior Day VWAP (from prior RTH open)", group=grpVis)
showSessionVwap = input.bool(true, "Session VWAP", group=grpVis)
showLabels = input.bool(true, "Session Line Labels", group=grpVis)
orColor = input.color(color.orange, "OR Color", group=grpVis)
onColor = input.color(color.teal, "Overnight Color", group=grpVis)
pdColor = input.color(color.purple, "Prev Day Color", group=grpVis)
priorDayVwapColor = input.color(color.new(#E040FB, 0), "Prior Day VWAP Color", group=grpVis)
sessionVwapColor = input.color(color.black, "Session VWAP Color", group=grpVis)
lineWidth = input.int(2, "Line Width", minval=1, maxval=4, group=grpVis)

// ── Calendar ─────────────────────────────────────────────────────────────────
var int[] usMarketHolidays = array.from(
     20240101, 20240115, 20240219, 20240329, 20240527, 20240619, 20240704, 20240902, 20241128, 20241225,
     20250101, 20250120, 20250217, 20250418, 20250526, 20250619, 20250704, 20250901, 20251127, 20251225,
     20260101, 20260119, 20260216, 20260403, 20260525, 20260619, 20260703, 20260907, 20261126, 20261225,
     20270101, 20270118, 20270215, 20270326, 20270531, 20270618, 20270705, 20270906, 20271125, 20271224)

// FOMC statement release days (second day of each meeting, America/New_York)
var int[] fomcDates = array.from(
     20240131, 20240320, 20240501, 20240612, 20240731, 20240918, 20241107, 20241218,
     20250129, 20250319, 20250507, 20250618, 20250730, 20250917, 20251029, 20251210,
     20260128, 20260318, 20260429, 20260617, 20260729, 20260916, 20261028, 20261209,
     20270127, 20270317, 20270428, 20270609, 20270728, 20270915, 20271027, 20271208)

isUsHoliday(int ymd) =>
    skipUsHolidays and array.includes(usMarketHolidays, ymd)

isFomcDay(int ymd) =>
    skipFomcDays and array.includes(fomcDates, ymd)

barDateKey = year(time, tz) * 10000 + month(time, tz) * 100 + dayofmonth(time, tz)
isTradingDay = dayofweek(time, tz) != dayofweek.saturday and dayofweek(time, tz) != dayofweek.sunday and not isUsHoliday(barDateKey) and not isFomcDay(barDateKey)

inRth = not na(time(timeframe.period, rthSession, tz))
inOvernight = not inRth
rthStarted = inRth and not inRth[1] and isTradingDay
rthEnded = inRth[1] and not inRth

entryCutoffMinsCt = entryEndHourCt * 60 + entryEndMinuteCt
flattenCutoffMinsCt = flattenEndHourCt * 60 + flattenEndMinuteCt
barMinsCt = hour(time, tzCt) * 60 + minute(time, tzCt)
beforeEntryCutoff = barMinsCt < entryCutoffMinsCt

entryStartMinsEt = entryStartHourEt * 60 + entryStartMinuteEt
barMinsEt = hour(time, tz) * 60 + minute(time, tz)
afterEntryStart = barMinsEt >= entryStartMinsEt

orDurationMs = orMinutes * 60 * 1000

// ── Opening range (first N minutes of RTH) ───────────────────────────────────
var float orHigh = na
var float orLow = na
var bool orReady = false
var int orStartTime = na
var int sessionStartBar = na

// ── ONH/ONL & PDH/PDL ───────────────────────────────────────────────────────
var float onHigh = na
var float onLow = na
var float pdHigh = na
var float pdLow = na
var float rthHigh = na
var float rthLow = na
var int priorSessionStartBar = na
var float ovnTrackHigh = na
var float ovnTrackLow = na

if rthStarted
    orHigh := na
    orLow := na
    orReady := false
    orStartTime := time
    sessionStartBar := bar_index
    rthHigh := na
    rthLow := na

if inRth and isTradingDay and not na(orStartTime) and not orReady
    elapsed = time - orStartTime
    if elapsed < orDurationMs
        orHigh := na(orHigh) ? high : math.max(orHigh, high)
        orLow := na(orLow) ? low : math.min(orLow, low)
    else if not na(orHigh) and not na(orLow)
        orReady := true

if inRth and isTradingDay
    rthHigh := na(rthHigh) ? high : math.max(rthHigh, high)
    rthLow := na(rthLow) ? low : math.min(rthLow, low)

if inOvernight
    ovnTrackHigh := na(ovnTrackHigh) ? high : math.max(ovnTrackHigh, high)
    ovnTrackLow := na(ovnTrackLow) ? low : math.min(ovnTrackLow, low)

if rthStarted
    onHigh := ovnTrackHigh
    onLow := ovnTrackLow
    ovnTrackHigh := na
    ovnTrackLow := na

if rthEnded and isTradingDay[1]
    pdHigh := rthHigh
    pdLow := rthLow
    priorSessionStartBar := sessionStartBar
    rthHigh := na
    rthLow := na
    ovnTrackHigh := high
    ovnTrackLow := low

// ── Prior day VWAP (anchored at previous RTH session open) ───────────────────
vwapSrc = hlc3
barVol = math.max(nz(volume), 1)

var float priorDayCumPv = na
var float priorDayCumV = na
var int lastPriorAnchor = na

priorAnchorChanged = not na(priorSessionStartBar) and (na(lastPriorAnchor) or priorSessionStartBar != lastPriorAnchor)

if priorAnchorChanged
    lastPriorAnchor := priorSessionStartBar
    priorDayCumPv := 0.0
    priorDayCumV := 0.0
    barsBack = bar_index - priorSessionStartBar
    for i = 0 to barsBack
        priorDayCumPv += hlc3[i] * math.max(nz(volume[i]), 1)
        priorDayCumV += math.max(nz(volume[i]), 1)
else if not na(priorSessionStartBar) and bar_index > priorSessionStartBar
    priorDayCumPv := nz(priorDayCumPv[1], 0.0) + vwapSrc * barVol
    priorDayCumV := nz(priorDayCumV[1], 0.0) + barVol

priorDayVwap = not na(priorDayCumV) and priorDayCumV > 0 ? priorDayCumPv / priorDayCumV : na
showPriorVwap = showPriorDayVwap and inRth and isTradingDay and not na(priorDayVwap)

plot(showPriorVwap ? priorDayVwap : na, "Prior Day VWAP", color=priorDayVwapColor, linewidth=lineWidth, style=plot.style_linebr, display=display.pane)

// ── Session VWAP (resets at RTH open) ────────────────────────────────────────
var float sessVwapCumPv = 0.0
var float sessVwapCumV = 0.0

if rthStarted
    sessVwapCumPv := vwapSrc * barVol
    sessVwapCumV := barVol
else if inRth and isTradingDay
    sessVwapCumPv += vwapSrc * barVol
    sessVwapCumV += barVol

sessionVwap = sessVwapCumV > 0 ? sessVwapCumPv / sessVwapCumV : na
showSessVwap = showSessionVwap and inRth and isTradingDay and not na(sessionVwap)

plot(showSessVwap ? sessionVwap : na, "Session VWAP", color=sessionVwapColor, linewidth=lineWidth, style=plot.style_linebr, display=display.pane)

// ── Session lines + labels ───────────────────────────────────────────────────
var line orHighLine = na
var line orLowLine = na
var line onHighLine = na
var line onLowLine = na
var line pdHighLine = na
var line pdLowLine = na
var label orHighLbl = na
var label orLowLbl = na
var label onHighLbl = na
var label onLowLbl = na
var label pdHighLbl = na
var label pdLowLbl = na
var label priorDayVwapLbl = na
var label sessVwapLbl = na

newLevelLine(int x1, float price, color clr, bool dashed) =>
    line.new(x1, price, bar_index, price, xloc=xloc.bar_index, extend=extend.none,
         color=clr, width=lineWidth, style=dashed ? line.style_dashed : line.style_solid)

syncLevelLabel(label lbl, string txt, float price, color clr) =>
    label out = lbl
    if showLabels
        if na(lbl)
            out := label.new(bar_index, price, txt, xloc=xloc.bar_index, style=label.style_none,
                 textcolor=clr, size=size.small)
        else
            label.set_x(lbl, bar_index)
            label.set_y(lbl, price)
    out

extendLevelLine(line ln, float price) =>
    if not na(ln) and inRth and not na(sessionStartBar)
        line.set_x1(ln, sessionStartBar)
        line.set_x2(ln, bar_index)
        line.set_y1(ln, price)
        line.set_y2(ln, price)

freezeLevelLine(line ln, int endBar, int startBar) =>
    if not na(ln)
        price = line.get_y1(ln)
        line.set_x1(ln, startBar)
        line.set_x2(ln, endBar)
        line.set_y1(ln, price)
        line.set_y2(ln, price)

freezeLevelLabel(label lbl, int endBar) =>
    if not na(lbl) and showLabels
        label.set_x(lbl, endBar)

if rthStarted
    orHighLine := na
    orLowLine := na
    onHighLine := na
    onLowLine := na
    pdHighLine := na
    pdLowLine := na
    orHighLbl := na
    orLowLbl := na
    onHighLbl := na
    onLowLbl := na
    pdHighLbl := na
    pdLowLbl := na
    priorDayVwapLbl := na
    sessVwapLbl := na

    if showOnLines and not na(onHigh)
        onHighLine := newLevelLine(sessionStartBar, onHigh, onColor, false)
    if showOnLines and not na(onLow)
        onLowLine := newLevelLine(sessionStartBar, onLow, onColor, false)
    if showPdLines and not na(pdHigh)
        pdHighLine := newLevelLine(sessionStartBar, pdHigh, pdColor, true)
    if showPdLines and not na(pdLow)
        pdLowLine := newLevelLine(sessionStartBar, pdLow, pdColor, true)

if orReady and showOrLines and na(orHighLine) and not na(orHigh) and not na(orLow)
    orHighLine := newLevelLine(sessionStartBar, orHigh, orColor, false)
    orLowLine := newLevelLine(sessionStartBar, orLow, orColor, false)

if inRth and isTradingDay
    if showOrLines and orReady
        extendLevelLine(orHighLine, orHigh)
        extendLevelLine(orLowLine, orLow)
        orHighLbl := syncLevelLabel(orHighLbl, "ORH", orHigh, orColor)
        orLowLbl := syncLevelLabel(orLowLbl, "ORL", orLow, orColor)
    if showOnLines
        extendLevelLine(onHighLine, onHigh)
        extendLevelLine(onLowLine, onLow)
        onHighLbl := syncLevelLabel(onHighLbl, "ONH", onHigh, onColor)
        onLowLbl := syncLevelLabel(onLowLbl, "ONL", onLow, onColor)
    if showPdLines
        extendLevelLine(pdHighLine, pdHigh)
        extendLevelLine(pdLowLine, pdLow)
        pdHighLbl := syncLevelLabel(pdHighLbl, "PDH", pdHigh, pdColor)
        pdLowLbl := syncLevelLabel(pdLowLbl, "PDL", pdLow, pdColor)
    if showPriorDayVwap and not na(priorDayVwap)
        priorDayVwapLbl := syncLevelLabel(priorDayVwapLbl, "PD VWAP", priorDayVwap, priorDayVwapColor)
    if showSessionVwap and not na(sessionVwap)
        sessVwapLbl := syncLevelLabel(sessVwapLbl, "VWAP", sessionVwap, sessionVwapColor)

if rthEnded and isTradingDay[1]
    if strategy.position_size > 0
        strategy.close("Long", comment="Session End")
    if strategy.position_size < 0
        strategy.close("Short", comment="Session End")
    endBar = bar_index - 1
    startBar = sessionStartBar
    if showOrLines and orReady
        freezeLevelLine(orHighLine, endBar, startBar)
        freezeLevelLine(orLowLine, endBar, startBar)
        freezeLevelLabel(orHighLbl, endBar)
        freezeLevelLabel(orLowLbl, endBar)
    if showOnLines
        freezeLevelLine(onHighLine, endBar, startBar)
        freezeLevelLine(onLowLine, endBar, startBar)
        freezeLevelLabel(onHighLbl, endBar)
        freezeLevelLabel(onLowLbl, endBar)
    if showPdLines
        freezeLevelLine(pdHighLine, endBar, startBar)
        freezeLevelLine(pdLowLine, endBar, startBar)
        freezeLevelLabel(pdHighLbl, endBar)
        freezeLevelLabel(pdLowLbl, endBar)
    if showPriorDayVwap
        freezeLevelLabel(priorDayVwapLbl, endBar)
    if showSessionVwap
        freezeLevelLabel(sessVwapLbl, endBar)
    orHighLine := na
    orLowLine := na
    onHighLine := na
    onLowLine := na
    pdHighLine := na
    pdLowLine := na
    orHighLbl := na
    orLowLbl := na
    onHighLbl := na
    onLowLbl := na
    pdHighLbl := na
    pdLowLbl := na
    priorDayVwapLbl := na
    sessVwapLbl := na

// ── VWAP Cross Strategy ──────────────────────────────────────────────────────
afterOrPeriod = orReady and not na(orStartTime) and (time - orStartTime) > orDurationMs
canEnter = beforeEntryCutoff and afterEntryStart and (waitForOr ? afterOrPeriod : (inRth and isTradingDay))

var bool tradedToday = false
var int lastLossExitBar = na
var int lastLongExitBar = na
var int lastShortExitBar = na
var bool flattenedAt2Pm = false
var float sessionStartNetProfit = na
var float tradeEntryPx = na
var float tradeRisk = na
var float trailStop = na
var bool trailing = false
var int tradeEntryTime = na
var int tradeEntryBar = na
var int longEntryBar = na
var int shortEntryBar = na
var float tradeStopPx = na
var float tradeTpPx = na
var float tradePartialPx = na
var bool partialTaken = false

var float positionStartNetProfit = na
var int consecLossTrades = 0
var int consecWinTradesDefense = 0
var bool lossStreakDefenseActive = false
var int lastClosedForStreak = 0
var bool ghostActive = false
var float ghostEntryPx = na
var float ghostStopPx = na
var float ghostPartialPx = na
var float ghostRisk = na
var int ghostDir = 0
var int ghostStartBar = na
var bool longWinWatchReclaim = false
var bool shortWinWatchReclaim = false
var bool skipNextLongReclaim = false
var bool skipNextShortReclaim = false

if rthStarted
    strategy.cancel_all()
    tradedToday := false
    lastLossExitBar := na
    lastLongExitBar := na
    lastShortExitBar := na
    flattenedAt2Pm := false
    sessionStartNetProfit := strategy.netprofit
    tradeEntryPx := na
    tradeRisk := na
    trailStop := na
    trailing := false
    tradeEntryTime := na
    tradeEntryBar := na
    longEntryBar := na
    shortEntryBar := na
    tradeStopPx := na
    tradeTpPx := na
    tradePartialPx := na
    partialTaken := false
    positionStartNetProfit := na
    longWinWatchReclaim := false
    shortWinWatchReclaim := false
    skipNextLongReclaim := false
    skipNextShortReclaim := false
    if ghostActive
        ghostActive := false
        ghostEntryPx := na
        ghostStopPx := na
        ghostPartialPx := na
        ghostRisk := na
        ghostDir := 0
        ghostStartBar := na

// Loss streak defense: consecutive losing / winning closed trades
if strategy.closedtrades > lastClosedForStreak and useLossStreakDefense
    exitPnl = strategy.closedtrades.profit(strategy.closedtrades - 1)
    if exitPnl < 0
        consecLossTrades += 1
        if lossStreakDefenseActive and lossStreakMode == "Reduce Size"
            consecWinTradesDefense := 0
        if consecLossTrades >= streakLossTrades
            lossStreakDefenseActive := true
    else if exitPnl > 0
        consecLossTrades := 0
        if lossStreakDefenseActive and lossStreakMode == "Reduce Size"
            consecWinTradesDefense += 1
            if consecWinTradesDefense >= streakWinTrades
                lossStreakDefenseActive := false
                consecWinTradesDefense := 0
    lastClosedForStreak := strategy.closedtrades

lossStreakPauseActive = useLossStreakDefense and lossStreakDefenseActive and lossStreakMode == "Pause"
lossStreakReduceActive = useLossStreakDefense and lossStreakDefenseActive and lossStreakMode == "Reduce Size"
defenseQtyEffective = math.min(defenseContracts, tradeQty)
activeQty = lossStreakReduceActive ? defenseQtyEffective : tradeQty
activePartialRr = partialExitRr
activeTrailRr = trailActivateRr

// Loss-only cooldown (current session)
if strategy.closedtrades > 0 and not na(sessionStartBar)
    lastIdx = strategy.closedtrades - 1
    exitBar = strategy.closedtrades.exit_bar_index(lastIdx)
    exitPnl = strategy.closedtrades.profit(lastIdx)
    if exitBar >= sessionStartBar and exitPnl < 0 and (na(lastLossExitBar) or exitBar > lastLossExitBar)
        lastLossExitBar := exitBar

inLossCooldown = not na(lastLossExitBar) and not na(sessionStartBar) and lastLossExitBar >= sessionStartBar and bar_index - lastLossExitBar < lossCooldown

if strategy.position_size == 0 and strategy.position_size[1] > 0
    lastLongExitBar := bar_index
    if not na(positionStartNetProfit) and strategy.netprofit > positionStartNetProfit
        longWinWatchReclaim := true
        skipNextLongReclaim := false
    positionStartNetProfit := na
if strategy.position_size == 0 and strategy.position_size[1] < 0
    lastShortExitBar := bar_index
    if not na(positionStartNetProfit) and strategy.netprofit > positionStartNetProfit
        shortWinWatchReclaim := true
        skipNextShortReclaim := false
    positionStartNetProfit := na

if useSkipFirstReclaimAfterWin and strategy.position_size == 0
    if longWinWatchReclaim and not na(sessionVwap) and close < sessionVwap
        skipNextLongReclaim := true
        longWinWatchReclaim := false
    if shortWinWatchReclaim and not na(sessionVwap) and close > sessionVwap
        skipNextShortReclaim := true
        shortWinWatchReclaim := false

inSameDirCooldownLong = sameDirCooldown > 0 and not na(lastLongExitBar) and not na(sessionStartBar) and lastLongExitBar >= sessionStartBar and bar_index - lastLongExitBar < sameDirCooldown
inSameDirCooldownShort = sameDirCooldown > 0 and not na(lastShortExitBar) and not na(sessionStartBar) and lastShortExitBar >= sessionStartBar and bar_index - lastShortExitBar < sameDirCooldown

liveStopBuf = stopBufferTicks * syminfo.mintick
paperStopBuf = pauseStopBufferTicks * syminfo.mintick

aboveBothVwap = not na(sessionVwap) and not na(priorDayVwap) and close > sessionVwap and close > priorDayVwap
belowBothVwap = not na(sessionVwap) and not na(priorDayVwap) and close < sessionVwap and close < priorDayVwap

crossAboveSessVwap = not na(sessionVwap) and close > sessionVwap and close[1] <= sessionVwap[1]
crossAbovePdVwap = not na(priorDayVwap) and close > priorDayVwap and close[1] <= priorDayVwap[1]
crossBelowSessVwap = not na(sessionVwap) and close < sessionVwap and close[1] >= sessionVwap[1]
crossBelowPdVwap = not na(priorDayVwap) and close < priorDayVwap and close[1] >= priorDayVwap[1]

priorRange = high[1] - low[1]
priorBodyPct = priorRange > 0 ? math.abs(close[1] - open[1]) / priorRange : 0.0
priorBearish = close[1] < open[1]
priorBullish = close[1] > open[1]
oppFilterOn = oppBodyPct > 0
oppFilterShortOn = oppBodyPctShort > 0

strongBearPrior = oppFilterOn and priorBearish and priorBodyPct >= oppBodyPct
strongBullPriorShort = oppFilterShortOn and priorBullish and priorBodyPct >= oppBodyPctShort

// ── Candlestick confirmation (signal bar + prior bar) ───────────────────────
candleRange = high - low
bodySize = math.abs(close - open)
upperWick = high - math.max(open, close)
lowerWick = math.min(open, close) - low
bodyPct = candleRange > 0 ? bodySize / candleRange : 0.0
clv = candleRange > 0 ? (close - low) / candleRange : 0.5
minCandleRange = syminfo.mintick * 8

isBullBar = close > open
isBearBar = close < open
isDojiBar = bodyPct <= 0.10

isHammer = candleRange >= minCandleRange and lowerWick >= bodySize * candlePinWickRatio and lowerWick > upperWick * 1.5
isShootingStar = candleRange >= minCandleRange and upperWick >= bodySize * candlePinWickRatio and upperWick > lowerWick * 1.5

bullEngulf = close[1] < open[1] and close > open and close > open[1] and open <= close[1]
bearEngulf = close[1] > open[1] and close < open and close < open[1] and open >= close[1]

bullMarubozu = isBullBar and bodyPct >= candleMinBodyPct and upperWick <= bodySize * 0.25 and lowerWick <= bodySize * 0.25
bearMarubozu = isBearBar and bodyPct >= candleMinBodyPct and upperWick <= bodySize * 0.25 and lowerWick <= bodySize * 0.25

candleConfirmLong = isHammer or bullEngulf or bullMarubozu or (isBullBar and clv >= candleClvThreshold)
candleOpposeLong = isShootingStar or bearEngulf or isDojiBar or not isBullBar

candleConfirmShort = isShootingStar or bearEngulf or bearMarubozu or (isBearBar and clv <= 1.0 - candleClvThreshold)
candleOpposeShort = isHammer or bullEngulf or isDojiBar or not isBearBar

candleAlignLong = not useCandleConfirm or (candleConfirmLong and not candleOpposeLong)
candleAlignShort = not useCandleConfirm or (candleConfirmShort and not candleOpposeShort)

longRiskEst = close - (low - liveStopBuf)
shortRiskEst = (high + liveStopBuf) - close
paperLongRiskEst = close - (low - paperStopBuf)
paperShortRiskEst = (high + paperStopBuf) - close

withinVwapDistLong = maxVwapDistPts <= 0 or (not na(sessionVwap) and close - sessionVwap <= maxVwapDistPts)
withinVwapDistShort = maxVwapDistPts <= 0 or (not na(sessionVwap) and sessionVwap - close <= maxVwapDistPts)

validLongRisk = maxEntryRiskPts <= 0 or longRiskEst <= maxEntryRiskPts
validShortRisk = maxEntryRiskPts <= 0 or shortRiskEst <= maxEntryRiskPts
paperValidLongRisk = maxEntryRiskPts <= 0 or paperLongRiskEst <= maxEntryRiskPts
paperValidShortRisk = maxEntryRiskPts <= 0 or paperShortRiskEst <= maxEntryRiskPts

barsSinceSession = not na(sessionStartBar) ? bar_index - sessionStartBar : 0
vwapSpreadNow = not na(sessionVwap) and not na(priorDayVwap) ? math.abs(sessionVwap - priorDayVwap) : na
vwapSpreadOk = minVwapSpreadPts <= 0 or (not na(vwapSpreadNow) and vwapSpreadNow >= minVwapSpreadPts)
canMeasureVwapFlat = barsSinceSession >= vwapSlopeLookback and not na(sessionVwap) and not na(priorDayVwap) and not na(sessionVwap[vwapSlopeLookback]) and not na(priorDayVwap[vwapSlopeLookback])
sessVwapSlopePts = canMeasureVwapFlat ? math.abs(sessionVwap - sessionVwap[vwapSlopeLookback]) : na
pdVwapSlopePts = canMeasureVwapFlat ? math.abs(priorDayVwap - priorDayVwap[vwapSlopeLookback]) : na
vwapsCompressed = maxVwapSpreadPts > 0 and not na(vwapSpreadNow) and vwapSpreadNow <= maxVwapSpreadPts
vwapsSloping = maxVwapSlopePts > 0 and sessVwapSlopePts <= maxVwapSlopePts and pdVwapSlopePts <= maxVwapSlopePts
bothVwapsFlat = skipFlatVwaps and canMeasureVwapFlat and vwapsCompressed and vwapsSloping

longVwapSetup = canEnter and aboveBothVwap and (crossAboveSessVwap or crossAbovePdVwap) and not strongBearPrior
shortVwapSetup = canEnter and belowBothVwap and (crossBelowSessVwap or crossBelowPdVwap) and not strongBullPriorShort

longSignalCore = longVwapSetup and withinVwapDistLong and validLongRisk and vwapSpreadOk and not bothVwapsFlat and candleAlignLong
shortSignalCore = shortVwapSetup and withinVwapDistShort and validShortRisk and vwapSpreadOk and not bothVwapsFlat and candleAlignShort
longPaperSignalCore = longVwapSetup and withinVwapDistLong and paperValidLongRisk and vwapSpreadOk and not bothVwapsFlat and candleAlignLong
shortPaperSignalCore = shortVwapSetup and withinVwapDistShort and paperValidShortRisk and vwapSpreadOk and not bothVwapsFlat and candleAlignShort

reclaimBlockLong = useSkipFirstReclaimAfterWin and skipNextLongReclaim and longSignalCore
reclaimBlockShort = useSkipFirstReclaimAfterWin and skipNextShortReclaim and shortSignalCore

if reclaimBlockLong
    skipNextLongReclaim := false
if reclaimBlockShort
    skipNextShortReclaim := false

longSignal = longSignalCore and not reclaimBlockLong
shortSignal = shortSignalCore and not reclaimBlockShort
longPaperSignal = longPaperSignalCore and not reclaimBlockLong
shortPaperSignal = shortPaperSignalCore and not reclaimBlockShort

canTradeBase = useStrategy and inRth and isTradingDay and beforeEntryCutoff and strategy.position_size == 0 and (not oneTradePerDay or not tradedToday) and not lossStreakPauseActive

canTradeLong = canTradeBase and not inLossCooldown and not inSameDirCooldownLong
canTradeShort = canTradeBase and not inLossCooldown and not inSameDirCooldownShort

tradeBlockReason() =>
    if not useStrategy
        "Strategy off"
    else if not inRth
        "Outside RTH"
    else if isFomcDay(barDateKey)
        "FOMC day"
    else if isUsHoliday(barDateKey)
        "Holiday"
    else if not isTradingDay
        "No session"
    else if not beforeEntryCutoff
        "After cutoff"
    else if not afterEntryStart
        "Before 10am"
    else if waitForOr and not afterOrPeriod
        "Wait for OR"
    else if strategy.position_size != 0
        "In position"
    else if oneTradePerDay and tradedToday
        "1 trade/day"
    else if lossStreakPauseActive
        "Paused"
    else if inLossCooldown
        "Loss cooldown"
    else if inSameDirCooldownLong or inSameDirCooldownShort
        "Same dir cooldown"
    else
        "Blocked"

if barstate.isconfirmed and canTradeLong and longSignal
    entryPx = close
    stopPx = low - liveStopBuf
    risk = longRiskEst
    if risk > 0
        strategy.entry("Long", strategy.long, qty=activeQty)
        tradedToday := true
        positionStartNetProfit := strategy.netprofit
        tradeEntryPx := entryPx
        tradeRisk := risk
        tradeEntryTime := time
        tradeEntryBar := bar_index
        longEntryBar := bar_index
        tradeStopPx := stopPx
        tradeTpPx := entryPx + risk * rrRatio
        tradePartialPx := entryPx + risk * activePartialRr
        partialTaken := false
        trailing := false
        trailStop := na

if barstate.isconfirmed and canTradeShort and shortSignal
    entryPx = close
    stopPx = high + liveStopBuf
    risk = shortRiskEst
    if risk > 0
        strategy.entry("Short", strategy.short, qty=activeQty)
        tradedToday := true
        positionStartNetProfit := strategy.netprofit
        tradeEntryPx := entryPx
        tradeRisk := risk
        tradeEntryTime := time
        tradeEntryBar := bar_index
        shortEntryBar := bar_index
        tradeStopPx := stopPx
        tradeTpPx := entryPx - risk * rrRatio
        tradePartialPx := entryPx - risk * activePartialRr
        partialTaken := false
        trailing := false
        trailStop := na

// ── Paper trade while paused (simulated win re-enables live trading) ─────────
paperCanBase = useStrategy and lossStreakPauseActive and inRth and isTradingDay and beforeEntryCutoff and strategy.position_size == 0 and not ghostActive

if barstate.isconfirmed and paperCanBase and longPaperSignal
    entryPx = close
    risk = paperLongRiskEst
    if risk > 0
        ghostActive := true
        ghostEntryPx := entryPx
        ghostStopPx := low - paperStopBuf
        ghostRisk := risk
        ghostPartialPx := entryPx + risk * pauseSimWinRr
        ghostDir := 1
        ghostStartBar := bar_index

if barstate.isconfirmed and paperCanBase and shortPaperSignal
    entryPx = close
    risk = paperShortRiskEst
    if risk > 0
        ghostActive := true
        ghostEntryPx := entryPx
        ghostStopPx := high + paperStopBuf
        ghostRisk := risk
        ghostPartialPx := entryPx - risk * pauseSimWinRr
        ghostDir := -1
        ghostStartBar := bar_index

ghostArmed = ghostActive and not na(ghostStartBar) and bar_index > ghostStartBar

if ghostArmed and flattenAt2Pm and inRth and isTradingDay and barMinsCt >= flattenCutoffMinsCt
    ghostActive := false
    ghostEntryPx := na
    ghostStopPx := na
    ghostPartialPx := na
    ghostRisk := na
    ghostDir := 0
    ghostStartBar := na

if ghostArmed and ghostDir == 1
    if low <= ghostStopPx
        ghostActive := false
        ghostEntryPx := na
        ghostStopPx := na
        ghostPartialPx := na
        ghostRisk := na
        ghostDir := 0
        ghostStartBar := na
    else if high >= ghostPartialPx and low > ghostStopPx
        lossStreakDefenseActive := false
        consecLossTrades := 0
        consecWinTradesDefense := 0
        ghostActive := false
        ghostEntryPx := na
        ghostStopPx := na
        ghostPartialPx := na
        ghostRisk := na
        ghostDir := 0
        ghostStartBar := na
        if showSkipLabels
            label.new(bar_index, high, "Paper Win", style=label.style_label_down, color=color.new(color.lime, 70), textcolor=color.lime, size=size.small)

if ghostArmed and ghostDir == -1
    if high >= ghostStopPx
        ghostActive := false
        ghostEntryPx := na
        ghostStopPx := na
        ghostPartialPx := na
        ghostRisk := na
        ghostDir := 0
        ghostStartBar := na
    else if low <= ghostPartialPx and high < ghostStopPx
        lossStreakDefenseActive := false
        consecLossTrades := 0
        consecWinTradesDefense := 0
        ghostActive := false
        ghostEntryPx := na
        ghostStopPx := na
        ghostPartialPx := na
        ghostRisk := na
        ghostDir := 0
        ghostStartBar := na
        if showSkipLabels
            label.new(bar_index, low, "Paper Win", style=label.style_label_up, color=color.new(color.lime, 70), textcolor=color.lime, size=size.small)

ghostStartedLong = ghostActive and ghostDir == 1 and ghostStartBar == bar_index
ghostStartedShort = ghostActive and ghostDir == -1 and ghostStartBar == bar_index

enteredLongThisBar = not na(longEntryBar) and longEntryBar == bar_index
enteredShortThisBar = not na(shortEntryBar) and shortEntryBar == bar_index
longSkipped = useStrategy and showSkipLabels and longVwapSetup and not enteredLongThisBar
shortSkipped = useStrategy and showSkipLabels and shortVwapSetup and not enteredShortThisBar
longFilterSkip = longVwapSetup and not longSignal
shortFilterSkip = shortVwapSetup and not shortSignal

exitsArmed = strategy.position_size != 0 and not na(tradeEntryBar) and bar_index > tradeEntryBar
partialQty = int(math.floor(activeQty * partialExitPct / 100.0))
canPartial = not partialTaken and partialQty >= 1 and partialQty < activeQty

// Flatten all open trades at 2PM CT
if flattenAt2Pm and inRth and isTradingDay and not flattenedAt2Pm and barMinsCt >= flattenCutoffMinsCt
    if strategy.position_size > 0
        strategy.close("Long", comment="2PM Flatten")
    if strategy.position_size < 0
        strategy.close("Short", comment="2PM Flatten")
    flattenedAt2Pm := true

// ── Exit pipeline: stop (all remaining) → 2R partial → trail activate → TP ──
// Update swing trail level only after trailing is already active
if exitsArmed and trailing and strategy.position_size > 0 and not na(tradeEntryPx)
    swingLow = low
    for j = 1 to trailLookback - 1
        swingLow := math.min(swingLow, low[j])
    newTrail = swingLow - liveStopBuf
    if na(trailStop) or newTrail > trailStop
        trailStop := newTrail

if exitsArmed and trailing and strategy.position_size < 0 and not na(tradeEntryPx)
    swingHigh = high
    for j = 1 to trailLookback - 1
        swingHigh := math.max(swingHigh, high[j])
    newTrail = swingHigh + liveStopBuf
    if na(trailStop) or newTrail < trailStop
        trailStop := newTrail

activeStopPx = trailing and not na(trailStop) ? trailStop : tradeStopPx

// 1) Stop / trail — close ALL open contracts immediately when stop is touched
if exitsArmed and not na(activeStopPx)
    if strategy.position_size > 0 and low <= activeStopPx
        strategy.cancel("Long TP")
        strategy.close("Long", comment=trailing ? "Trail Stop" : "Stop Loss")
    if strategy.position_size < 0 and high >= activeStopPx
        strategy.cancel("Short TP")
        strategy.close("Short", comment=trailing ? "Trail Stop" : "Stop Loss")

// 2) Partial at 2R (runner stays on for trail — checked before trail activates this bar)
partialComment = str.tostring(activePartialRr, "#.#") + "R Partial"
if exitsArmed and canPartial and not na(tradePartialPx)
    if strategy.position_size > 0 and high >= tradePartialPx and low > tradeStopPx
        strategy.close("Long", qty=partialQty, comment=partialComment)
        partialTaken := true
    if strategy.position_size < 0 and low <= tradePartialPx and high < tradeStopPx
        strategy.close("Short", qty=partialQty, comment=partialComment)
        partialTaken := true

// 3) Activate swing trail on runner at trail R:R (default 2R — after partial can fill)
if exitsArmed and not trailing and strategy.position_size > 0 and not na(tradeEntryPx) and not na(tradeRisk)
    if high >= tradeEntryPx + tradeRisk * activeTrailRr
        trailing := true
        strategy.cancel("Long TP")
        swingLow = low
        for j = 1 to trailLookback - 1
            swingLow := math.min(swingLow, low[j])
        trailStop := swingLow - liveStopBuf
if exitsArmed and not trailing and strategy.position_size < 0 and not na(tradeEntryPx) and not na(tradeRisk)
    if low <= tradeEntryPx - tradeRisk * activeTrailRr
        trailing := true
        strategy.cancel("Short TP")
        swingHigh = high
        for j = 1 to trailLookback - 1
            swingHigh := math.max(swingHigh, high[j])
        trailStop := swingHigh + liveStopBuf

// 4) Hard TP at 3R while still pre-trail (optional cap before runner trails)
if exitsArmed and not trailing
    if strategy.position_size > 0
        strategy.exit("Long TP", "Long", limit=tradeTpPx, comment="Take Profit")
    if strategy.position_size < 0
        strategy.exit("Short TP", "Short", limit=tradeTpPx, comment="Take Profit")

if strategy.position_size == 0 and not na(tradeEntryBar) and bar_index > tradeEntryBar
    tradeEntryBar := na
    longEntryBar := na
    shortEntryBar := na
    tradeStopPx := na
    tradeTpPx := na
    tradePartialPx := na
    partialTaken := false

plotshape(enteredLongThisBar, "Long Signal", shape.triangleup, location.belowbar, color.new(color.lime, 0), size=size.small, display=display.all - display.status_line)
plotshape(enteredShortThisBar, "Short Signal", shape.triangledown, location.abovebar, color.new(color.red, 0), size=size.small, display=display.all - display.status_line)
plotshape(ghostStartedLong, "Paper Long", shape.circle, location.belowbar, color.new(color.aqua, 0), size=size.tiny, display=display.all - display.status_line, text="Paper")
plotshape(ghostStartedShort, "Paper Short", shape.circle, location.abovebar, color.new(color.aqua, 0), size=size.tiny, display=display.all - display.status_line, text="Paper")
bgcolor(lossStreakPauseActive and inRth ? color.new(color.red, 93) : na, title="Paused")
bgcolor(lossStreakReduceActive and inRth ? color.new(color.orange, 93) : na, title="Reduced Size")
bgcolor(lossStreakPauseActive and ghostActive and inRth ? color.new(color.aqua, 95) : na, title="Paper Trade")

// ── Skip reason text on chart ────────────────────────────────────────────────
canSkipBase = strategy.position_size == 0 and not inLossCooldown

plotshape(longSkipped and strategy.position_size != 0, "Skip: In pos", shape.xcross, location.abovebar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="In position")
plotshape(longSkipped and canSkipBase and inLossCooldown, "Skip: Loss CD L", shape.xcross, location.abovebar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="Cooldown")
plotshape(longSkipped and canSkipBase and not inLossCooldown and inSameDirCooldownLong, "Skip: Same dir CD L", shape.xcross, location.abovebar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="Re-entry CD")
plotshape(longSkipped and canSkipBase and not inLossCooldown and not inSameDirCooldownLong and lossStreakPauseActive and not ghostActive, "Skip: Paused L", shape.xcross, location.abovebar, color.new(color.red, 0), size=size.tiny, display=display.all - display.status_line, text="Paused")
plotshape(longSkipped and canSkipBase and not inLossCooldown and not inSameDirCooldownLong and not lossStreakPauseActive and oneTradePerDay and tradedToday, "Skip: 1/day", shape.xcross, location.abovebar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="1 trade/day")
plotshape(longSkipped and canSkipBase and not inLossCooldown and not inSameDirCooldownLong and not beforeEntryCutoff, "Skip: Cutoff", shape.xcross, location.abovebar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="After cutoff")
plotshape(longSkipped and canSkipBase and not inLossCooldown and not inSameDirCooldownLong and not afterEntryStart, "Skip: Early L", shape.xcross, location.abovebar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="Before 10am")
plotshape(longSkipped and canSkipBase and not inLossCooldown and not inSameDirCooldownLong and afterEntryStart and waitForOr and not afterOrPeriod, "Skip: OR wait", shape.xcross, location.abovebar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="Wait for OR")
plotshape(longFilterSkip and canSkipBase and not inSameDirCooldownLong and beforeEntryCutoff and afterEntryStart and withinVwapDistLong and validLongRisk and reclaimBlockLong, "Skip: Reclaim L", shape.xcross, location.abovebar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="Reclaim skip")
plotshape(longFilterSkip and canSkipBase and not inSameDirCooldownLong and beforeEntryCutoff and afterEntryStart and withinVwapDistLong and validLongRisk and not reclaimBlockLong and not vwapSpreadOk, "Skip: Tight spread L", shape.xcross, location.abovebar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="Tight spread")
plotshape(longFilterSkip and canSkipBase and not inSameDirCooldownLong and beforeEntryCutoff and afterEntryStart and withinVwapDistLong and validLongRisk and not reclaimBlockLong and vwapSpreadOk and bothVwapsFlat, "Skip: Flat VWAP L", shape.xcross, location.abovebar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="Flat VWAP")
plotshape(longFilterSkip and canSkipBase and not inSameDirCooldownLong and beforeEntryCutoff and afterEntryStart and not withinVwapDistLong, "Skip: Far VWAP L", shape.xcross, location.abovebar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="Far VWAP")
plotshape(longFilterSkip and canSkipBase and not inSameDirCooldownLong and beforeEntryCutoff and afterEntryStart and withinVwapDistLong and not validLongRisk, "Skip: Wide stop L", shape.xcross, location.abovebar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="Wide stop")
plotshape(longFilterSkip and canSkipBase and not inSameDirCooldownLong and beforeEntryCutoff and afterEntryStart and withinVwapDistLong and validLongRisk and not reclaimBlockLong and vwapSpreadOk and not bothVwapsFlat and useCandleConfirm and not candleAlignLong, "Skip: Bad candle L", shape.xcross, location.abovebar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="Bad candle")

plotshape(shortSkipped and strategy.position_size != 0, "Skip: In pos S", shape.xcross, location.belowbar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="In position")
plotshape(shortSkipped and canSkipBase and inLossCooldown, "Skip: Loss CD S", shape.xcross, location.belowbar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="Cooldown")
plotshape(shortSkipped and canSkipBase and not inLossCooldown and inSameDirCooldownShort, "Skip: Same dir CD S", shape.xcross, location.belowbar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="Re-entry CD")
plotshape(shortSkipped and canSkipBase and not inLossCooldown and not inSameDirCooldownShort and lossStreakPauseActive and not ghostActive, "Skip: Paused S", shape.xcross, location.belowbar, color.new(color.red, 0), size=size.tiny, display=display.all - display.status_line, text="Paused")
plotshape(shortSkipped and canSkipBase and not inLossCooldown and not inSameDirCooldownShort and not lossStreakPauseActive and oneTradePerDay and tradedToday, "Skip: 1/day S", shape.xcross, location.belowbar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="1 trade/day")
plotshape(shortSkipped and canSkipBase and not inLossCooldown and not inSameDirCooldownShort and not beforeEntryCutoff, "Skip: Cutoff S", shape.xcross, location.belowbar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="After cutoff")
plotshape(shortSkipped and canSkipBase and not inLossCooldown and not inSameDirCooldownShort and not afterEntryStart, "Skip: Early S", shape.xcross, location.belowbar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="Before 10am")
plotshape(shortSkipped and canSkipBase and not inLossCooldown and not inSameDirCooldownShort and afterEntryStart and waitForOr and not afterOrPeriod, "Skip: OR wait S", shape.xcross, location.belowbar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="Wait for OR")
plotshape(shortFilterSkip and canSkipBase and not inSameDirCooldownShort and beforeEntryCutoff and afterEntryStart and withinVwapDistShort and validShortRisk and reclaimBlockShort, "Skip: Reclaim S", shape.xcross, location.belowbar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="Reclaim skip")
plotshape(shortFilterSkip and canSkipBase and not inSameDirCooldownShort and beforeEntryCutoff and afterEntryStart and withinVwapDistShort and validShortRisk and not reclaimBlockShort and not vwapSpreadOk, "Skip: Tight spread S", shape.xcross, location.belowbar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="Tight spread")
plotshape(shortFilterSkip and canSkipBase and not inSameDirCooldownShort and beforeEntryCutoff and afterEntryStart and withinVwapDistShort and validShortRisk and not reclaimBlockShort and vwapSpreadOk and bothVwapsFlat, "Skip: Flat VWAP S", shape.xcross, location.belowbar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="Flat VWAP")
plotshape(shortFilterSkip and canSkipBase and not inSameDirCooldownShort and beforeEntryCutoff and afterEntryStart and not withinVwapDistShort, "Skip: Far VWAP S", shape.xcross, location.belowbar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="Far VWAP")
plotshape(shortFilterSkip and canSkipBase and not inSameDirCooldownShort and beforeEntryCutoff and afterEntryStart and withinVwapDistShort and not validShortRisk, "Skip: Wide stop S", shape.xcross, location.belowbar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="Wide stop")
plotshape(shortFilterSkip and canSkipBase and not inSameDirCooldownShort and beforeEntryCutoff and afterEntryStart and withinVwapDistShort and validShortRisk and not reclaimBlockShort and vwapSpreadOk and not bothVwapsFlat and useCandleConfirm and not candleAlignShort, "Skip: Bad candle S", shape.xcross, location.belowbar, color.new(color.orange, 0), size=size.tiny, display=display.all - display.status_line, text="Bad candle")

// PnL label on trade exit
var int prevClosedTrades = 0
if strategy.closedtrades > prevClosedTrades
    pnl = strategy.closedtrades.profit(strategy.closedtrades - 1)
    pnlStr = pnl >= 0 ? "+" + str.tostring(pnl, "#.##") : str.tostring(pnl, "#.##")
    lbl_clr = pnl >= 0 ? color.lime : color.red
    exitBar = strategy.closedtrades.exit_bar_index(strategy.closedtrades - 1)
    exitPrice = strategy.closedtrades.exit_price(strategy.closedtrades - 1)
    isLong = strategy.closedtrades.size(strategy.closedtrades - 1) > 0
    lbl_style = isLong ? label.style_label_up : label.style_label_down
    lbl_y = isLong ? exitPrice - syminfo.mintick * 20 : exitPrice + syminfo.mintick * 20
    label.new(exitBar, lbl_y, "$" + pnlStr, xloc=xloc.bar_index, style=lbl_style,
         color=color.new(lbl_clr, 70), textcolor=lbl_clr, size=size.normal)
    prevClosedTrades := strategy.closedtrades
